# Local VS Code workspace settings
.vscode/settings.json

# Generated artifacts
**/logs/*
!**/logs/.gitkeep
**/Logs/*
!**/Logs/.gitkeep
**/reports/*
!**/reports/.gitkeep
**/Reports/*
!**/Reports/.gitkeep
**/state/*
!**/state/.gitkeep
**/State/*
!**/State/.gitkeep
*.state.json

# Keep scripts folders present but empty in Git
**/scripts/*
!**/scripts/.gitkeep

# Keep static artifacts local only
**/static/
**/Static/

# Local demo folders (do not upload)
**/demo/
**/Demo/
